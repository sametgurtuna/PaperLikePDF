{
  "manifest_version": 3,
  "name": "PaperLike - PDF Paper Texture",
  "version": "1.4.0",
  "description": "Adds a subtle paper-like texture overlay and flipbook reading mode to PDF documents.",
  "minimum_chrome_version": "114",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_title": "PaperLike",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*.pdf",
        "*://*/*.pdf?*",
        "file:///*.pdf",
        "file:///*.pdf?*"
      ],
      "js": [
        "shared.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "flipbook.html",
        "flipbook.js",
        "flipbook.css",
        "shared.js",
        "lib/*",
        "assets/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "toggle-paperlike": {
      "suggested_key": {
        "default": "Alt+P"
      },
      "description": "Toggle the paper texture overlay"
    }
  }
}